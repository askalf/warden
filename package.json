{
  "name": "@askalf/warden",
  "version": "0.2.1",
  "description": "own your agent security — a guard between an agent and its tools: risk classification, policy, secret-exfil + prompt-injection defense, tamper-evident audit, MCP middleware. Part of Own Your Stack.",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./mcp": "./src/mcp.mjs",
    "./judge": "./src/judge.mjs",
    "./wrap": "./src/wrap.mjs",
    "./daemon": "./src/daemon.mjs",
    "./client": "./src/client.mjs",
    "./audit": "./src/audit.mjs",
    "./scan": "./src/scan.mjs"
  },
  "bin": {
    "warden": "./src/cli.mjs",
    "warden-mcp": "./src/mcp-proxy-cli.mjs",
    "warden-hook": "./src/cc-hook.mjs",
    "warden-serve": "./src/daemon-cli.mjs"
  },
  "scripts": {
    "test": "node --test",
    "demo": "node demo/demo.mjs",
    "smoke": "node demo/mcp-smoke.mjs",
    "smoke:native": "node native/smoke.mjs",
    "bench": "node bench/run.mjs",
    "bench:redos": "node bench/redos.mjs",
    "bench:stress": "node bench/stress.mjs && node bench/stress2.mjs && node bench/edgecases.mjs",
    "bench:mcp": "node bench/mcp-redteam.mjs",
    "bench:max": "node bench/maxstress.mjs",
    "bench:native": "node native/bench.mjs",
    "arena": "node arena/run.mjs",
    "arena:corpus": "node arena/build-corpus.mjs"
  },
  "keywords": ["agent", "security", "mcp", "llm", "guardrails", "ai-safety", "firewall", "own-your-stack"],
  "author": "Thomas Sprayberry",
  "license": "MIT",
  "repository": "github:askalf/warden",
  "engines": { "node": ">=20" },
  "files": ["src"],
  "publishConfig": { "access": "public" }
}
